# =============================================================================
# BOOKME — VARIÁVEIS DE AMBIENTE
# Copiar para .env.local e preencher com os valores reais
# NUNCA commitar o ficheiro .env.local para o Git
# =============================================================================

# =============================================================================
# SUPABASE (Base de dados — OBRIGATÓRIO)
# Obter em: https://supabase.com/dashboard/project/_/settings/api
# =============================================================================
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# STRIPE (Pagamentos — necessário para planos pagos)
# Obter em: https://dashboard.stripe.com/apikeys
# =============================================================================
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — criar em: https://dashboard.stripe.com/products
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_YEARLY=price_...

# =============================================================================
# RESEND (Email — necessário para notificações)
# Obter em: https://resend.com/api-keys
# =============================================================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@bookme.pt
RESEND_FROM_NAME=BookMe

# =============================================================================
# TWILIO (WhatsApp — necessário para notificações WhatsApp)
# Obter em: https://console.twilio.com
# =============================================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_NUMBER=+14155552671

# =============================================================================
# TELEGRAM (Bot — necessário para notificações Telegram)
# Criar em: Telegram > @BotFather > /newbot
# =============================================================================
TELEGRAM_BOT_TOKEN=123456789:ABCDefGHIJKlmnoPQRstUVwxyz

# =============================================================================
# WEB PUSH — VAPID KEYS (PWA Notifications)
# Gerar com: npx web-push generate-vapid-keys
# =============================================================================
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:admin@bookme.pt

# =============================================================================
# GOOGLE ANALYTICS (opcional)
# Obter em: https://analytics.google.com
# =============================================================================
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# =============================================================================
# FACEBOOK PIXEL (opcional)
# Obter em: https://business.facebook.com/events_manager
# =============================================================================
VITE_FB_PIXEL_ID=...

# =============================================================================
# DOMÍNIO DA APLICAÇÃO
# =============================================================================
VITE_APP_URL=https://bookme.pt
VITE_APP_TITLE=BookMe
NODE_ENV=development
PORT=3000
